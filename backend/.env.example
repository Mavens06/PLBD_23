# Copier ce fichier en .env (à la racine du projet) et adapter si besoin.
# Ne jamais committer le fichier .env dans Git.

# --- Mode d'exécution --------------------------------------------------------
# mock     : PC de dev / démo sans matériel (robot + capteur simulés).
# hardware : Raspberry Pi avec le robot réel (et le capteur RS485 dès qu'il
#            est monté).
APP_MODE=mock

# --- Mode capteur (découplé du mode robot) ------------------------------------
# auto     : suit APP_MODE (défaut).
# mock     : mesures simulées MÊME en APP_MODE=hardware → mode « essai complet
#            sans capteur RS485 » : le robot roule réellement, le bras descend
#            réellement, la stabilisation et la collecte (~4 s + 10 lectures)
#            se déroulent en temps réel, mais les valeurs sont générées
#            (profils curés A1..C3 ou champ déterministe soil_at(x, y)).
# hardware : force le vrai capteur RS485 (repli mock automatique si init KO).
SENSOR_MODE=auto

# --- Valeurs aberrantes simulées (test bout-en-bout des garde-fous) -----------
# Probabilité [0..1] qu'un point de mesure produise un profil aberrant
# (salinité énorme, pH très acide, sol quasi sec, ou température en bordure de
# plage → qualité "suspect"). 0 = désactivé. Conseillé pour l'essai : 0.2-0.3.
SENSOR_MOCK_OUTLIER_RATE=0
# Et/ou labels de points FORCÉS en aberrant (ex. B2,C1). Vide = aucun.
SENSOR_MOCK_OUTLIER_POINTS=

# --- Robot Adeept PiCar-Pro (mode hardware) ----------------------------------
# Valeurs par défaut = VALIDÉES sur le robot (Code_PLBD_23_mission.py).
# À surcharger seulement si le câblage diffère.
PCA9685_ADDRESS=0x5f          # adresse I2C du PCA9685
PCA9685_FREQUENCY=50          # Hz
MOTOR_LEFT_IN1=15             # canaux PCA du moteur gauche
MOTOR_LEFT_IN2=14
MOTOR_RIGHT_IN1=12            # canaux PCA du moteur droit
MOTOR_RIGHT_IN2=13
STEER_SERVO_CHANNEL=0         # canal du servo de direction
STEER_CENTER_DEG=85           # roues droites
STEER_LEFT_DEG=0              # braquage gauche à fond
STEER_RIGHT_DEG=180           # braquage droit à fond
# Throttles SIGNÉS validés sur le robot : la marche AVANT est NÉGATIVE.
DRIVE_THROTTLE=-0.15          # ligne droite (avant = négatif sur ce câblage)
TURN_THROTTLE=0.18            # pendant les virages en arc
TURN_90_S=1.2                 # durée d'un quart de tour en arc (~90°)
ROBOT_SPEED_MPS=0.19          # ≈35-40 cm en 2 s à 0.15 de throttle

# --- Échelle monde (démo sur surface réduite) ---------------------------------
# Le plan de l'interface est en mètres « terrain » ; le robot multiplie chaque
# distance par ce facteur pour le déplacement PHYSIQUE uniquement (l'interface
# et les mesures ne changent pas). Démo 1 m × 1 m avec la grille 3×3 par défaut
# (6 m d'envergure) : 0.15 → ~90 cm parcourus. 1.0 = grandeur réelle.
ROBOT_WORLD_SCALE=1.0
# Revenir à l'origine (0,0) en fin de mission (jamais après un arrêt d'urgence).
ROBOT_RETURN_HOME=0

# --- Ultrason anti-obstacle (broches validées sur le robot) -------------------
# Pendant les lignes droites, le robot vérifie l'ultrason toutes les ~0.4 s :
# obstacle plus près que le seuil → arrêt + LED + bip, puis reprise automatique
# quand la voie se dégage. Au-delà du timeout, la mission s'interrompt proprement
# (le daemon --watch survit et retourne en attente).
OBSTACLE_AVOIDANCE=1
ULTRASONIC_TRIGGER_PIN=23
ULTRASONIC_ECHO_PIN=24
OBSTACLE_MIN_DISTANCE_CM=12
OBSTACLE_TIMEOUT_S=20

# --- LEDs / buzzer de signalisation (broches validées) ------------------------
# Bip au démarrage, clignotement à chaque point atteint, bip aigu en fin de
# mission, LED + bip sur obstacle. No-op silencieux si indisponibles.
SIGNALS_ENABLED=1
LED_PINS=25,11
BUZZER_PIN=18

# --- Sonde = BRAS du PiCar-Pro (séquence validée) ------------------------------
# Laisser PROBE_SERVO_CHANNEL vide → descente simulée (log + pause).
# Pour l'essai complet : l'épaule du bras (canal 2) descend la « sonde »,
# les autres servos du bras sont tenus en posture home (1:90, 3:140, 4:80).
# Vérifier la séquence : APP_MODE=hardware python3 -m raspberry_pi.hardware_test --test servo
# PROBE_STABILIZE_S = pause « contact sol » après la descente, avant la collecte.
PROBE_SERVO_CHANNEL=2
PROBE_ANGLE_UP=90
PROBE_ANGLE_DOWN=150
PROBE_ARM_HOME=1:90,3:140,4:80
PROBE_STABILIZE_S=3.0

# --- LLM Gemini (Google AI Studio) ------------------------------------------
# Le chatbot s'interface avec Gemini via l'API Google AI Studio (cloud).
# Seule la couche conversationnelle (/api/chat) utilise le cloud ; l'inférence
# ML/règles reste 100% locale. Une connexion internet est requise pour le chat.
# Obtenir une clé gratuite : https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Choix du modèle (le code ne change pas, seule cette variable est adaptée) :
#   • gemini-2.5-flash       → recommandé (les modèles 2.0 ont un free tier à 0)
#   • gemini-2.5-flash-lite  → plus léger / rapide
# NB : selon le compte/la région, le free tier des modèles 2.0 peut être à 0
# (HTTP 429). Les modèles 2.5 disposent du quota gratuit.
GEMINI_MODEL=gemini-2.5-flash
# Modèle de repli automatique si le modèle principal sature son quota (HTTP 429).
# Par défaut gemini-2.5-flash-lite (quota gratuit plus large). Laisser vide pour
# désactiver le repli — le backend renverra alors directement l'erreur 429/503.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
# Timeout HTTP de l'appel Gemini (s).
GEMINI_TIMEOUT=60
# --- Synthèse vocale (TTS) Gemini -------------------------------------------
# Donne une vraie voix arabe naturelle (route /api/tts), indépendante des voix
# TTS locales du navigateur (souvent absentes pour l'arabe sous Chrome).
# La voix parle automatiquement la langue du texte. Voix dispo : Kore, Puck,
# Charon, Aoede, Fenrir, Leda, Orus, Zephyr… (cf. doc speech-generation).
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore

# --- Météo (Open-Meteo, sans clé) -------------------------------------------
# Enrichissement OPTIONNEL : affine l'irrigation selon la pluie prévue (route
# /api/weather). Sans réseau, l'API renvoie {available:false} et le cœur
# agronomique local continue de fonctionner. Localisation par défaut : plaine
# du Saïss (Maroc). Adapter aux coordonnées de la parcelle.
WEATHER_LAT=33.9
WEATHER_LON=-5.55
WEATHER_TIMEOUT=8

# --- Persistance backend -----------------------------------------------------
# Plan de mission + mesures sont persistés dans SQLite. Par défaut :
# .agribotics/state.sqlite3 à la racine du dépôt. Adapter si besoin.
AGRIBOTICS_DB_PATH=.agribotics/state.sqlite3

# --- Résilience réseau du robot (file d'attente hors-ligne) ------------------
# Si le backend est injoignable pendant une mission, le robot persiste les
# mesures dans ce fichier (JSON Lines) et les retransmet automatiquement à la
# mission suivante. Aucune mesure perdue au champ. Défaut : .agribotics/robot_outbox.jsonl
AGRIBOTICS_ROBOT_OUTBOX=.agribotics/robot_outbox.jsonl

# --- CORS -------------------------------------------------------------------
# Origines autorisées par le middleware CORS (séparées par des virgules).
# Laisser à * pour le développement local. En production, mettre l'URL exacte
# de l'interface web, ex. : http://192.168.1.42:5500
# NB : avec "*", les credentials sont automatiquement désactivés (combinaison
# invalide côté Starlette). Pour autoriser les credentials, lister les origines.
CORS_ORIGINS=*

# --- Sécurité API (optionnel mais recommandé pour un robot sur le réseau) -----
# Si défini, toutes les routes POST (mission/*, measurements, chat, tts) exigent
# l'en-tête HTTP `X-API-Key` égal à cette valeur (401 sinon). Les GET restent
# ouverts. Vide = authentification DÉSACTIVÉE (dev/démo : routes POST ouvertes).
# Le robot (raspberry_pi/main.py) lit la même variable ; le frontend l'envoie via
# window.AGRIBOTICS_API_KEY (à définir dans l'HTML servi).
AGRIBOTICS_API_KEY=
