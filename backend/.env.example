# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer le fichier .env dans Git.

# Clé API OpenAI – utilisée uniquement par chatbot_llm.py pour générer des
# réponses en langage naturel (français, arabe, darija).
# La Raspberry Pi effectue toujours le traitement des capteurs et les
# prédictions ML localement ; le LLM sert uniquement à humaniser le rendu.
OPENAI_API_KEY=your_api_key_here

# Origines autorisées par le middleware CORS (séparées par des virgules).
# Laisser à * pour le développement local. En production, mettre l'URL exacte
# de l'interface web, ex. : http://192.168.1.42:8080
CORS_ORIGINS=*
